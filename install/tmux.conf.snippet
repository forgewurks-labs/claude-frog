# Claude Frog — tmux toggle keybind
# Append to ~/.tmux.conf (or ~/.config/tmux/tmux.conf), then reload with:
#   tmux source-file ~/.tmux.conf
#
# Replace the path below with the real absolute path to claude_frog.py.

# prefix + F  →  hide / summon the frog for the current session
# Capital F is the frog's, by royal decree. Lowercase f stays find-window.
bind F run-shell "python3 /path/to/claude-frog/claude_frog.py toggle"

# Where he lives: top | bottom (7-line strip) or left | right (24-col tower).
# `top` is the default; uncomment and edit to move him. Set here (not via
# --layout) so the keybind and the SessionStart hook agree on one answer.
# set-environment -g CLAUDE_FROG_LAYOUT bottom

# Which console he's rendered as: snes (default) | genesis | gba. Like the
# layout, set it in the env so the keybind and the hook agree. Better still,
# export CLAUDE_FROG_THEME in your shell before launching Claude so each session
# can pick its own style.
# set-environment -g CLAUDE_FROG_THEME genesis
